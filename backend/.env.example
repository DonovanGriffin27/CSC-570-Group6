# Copy this file to .env and fill in your values.
# For local dev: install Postgres and MongoDB locally, then use the values below as-is (adjust as needed).
# For cloud: paste your Supabase connection string values and MongoDB Atlas URI.

# --- PostgreSQL ---
DB_HOST=localhost
DB_PORT=5432
DB_NAME=casevault
DB_USER=postgres
DB_PASS=yourpassword

# --- MongoDB ---
# Local:  mongodb://localhost:27017
# Atlas:  mongodb+srv://<user>:<pass>@<cluster>.mongodb.net
MONGO_URI=mongodb://localhost:27017

# --- Auth ---
# Any long random string works for local dev. Change before deploying.
JWT_SECRET=change_this_before_production
